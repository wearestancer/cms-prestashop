{
    "name": "stancer/cms-prestashop",
    "description": "Stancer PrestaShop module",
    "homepage": "https://stancer.com",
    "type": "prestashop-module",
    "license": "MIT",
    "config": {
        "prepend-autoloader": false,
        "sort-packages": true
    },
    "autoload": {
        "classmap": [
            "classes/",
            "controllers/",
            "vendors/"
        ]
    },
    "scripts": {
        "after:scoping": "bash ./scripts/clean-after-archives.sh && composer install",
        "phpcs": "./vendor/bin/php-cs-fixer check --diff",
        "phpcs-fix": "./vendor/bin/php-cs-fixer fix",
        "phpstan": "./vendor/bin/phpstan",
        "prefix-stancer": "bash ./scripts/class-prefixer.sh",
        "prep-vendor": "bash ./scripts/scoper-dl.sh && scoper add-prefix -nf && rm -rf vendor/*",
        "scope:dependency": "composer install --no-dev && composer run prep-vendor && composer run prefix-stancer && composer du"
    },
    "require": {
        "php": ">=7.4",
        "stancer/stancer": "^1.1.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "prestashop/php-dev-tools": "^4.3",
        "stancer/php-stubs-prestashop": "^1.7"
    },

    "support": {
        "docs": "https://gitlab.com/wearestancer/cms/prestashop/-/wikis/home",
        "issues": "https://gitlab.com/wearestancer/cms/prestashop/-/issues",
        "source": "https://gitlab.com/wearestancer/cms/prestashop"
    }
}
