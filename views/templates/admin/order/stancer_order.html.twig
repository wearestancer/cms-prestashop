{% import '@PrestaShop/Admin/macros.html.twig' as ps %}


<div class="card mt-2" id="view_order_stancer_block">
	<div id="stancerPaymentCard" class="payment card">
		<div class="card-header">
			<h3 class="card-header-title">
				{{translatedLabel.stancer_payment}}
			</h3>
		</div>
	</div>

	<div class="card-body">
		<div class="row mt-3">
			<div id="stancerPaymentId" class="col-xl-6">
				<p class="mb-1">
					<strong>{{translatedLabel.payment_id}}</strong>
				</p>
				<p>
					{{stancerForDisplay.id}}
				</p>
			</div>
			<div id="stancerPaymentStatus" class="col-xl-6">
        <div class="row">
        <div class='col-xxl-6'>
          <p class="mb-1">
            {{translatedLabel.status}}:
          </p>
          <h3>
            <span class="badge badge-dark font-size-100">{{stancerForDisplay.status}}</span>
          </h3>
        </div>
        {% if stancerForDisplay.status is same as('authorized') %}

          <div class='col-xxl-6' id='stancer_capture_form'>
            {{form(captureForm)}}
          </div>
        {% endif %}
        </div>
			</div>
		</div>

		<div class="info-block mt-2">
			<div id="stancerInfo" class="row mt-3">
				{% if stancerForDisplay.method is same as("card") %}
					<div id="cardBrand" class="info-block-col col-xl-6">
						<div class="row justify-content-between no-gutters">
            <p>
							<strong>{{translatedLabel.card_details}}</strong>
						</p>
            </div>
						<p class="mb-1">
							{{translatedLabel.card_brand}}{#'Card Brand:'|trans({},'Modules.Stancer.Stancer_order.html.twig')}}: #}
							{{stancerForDisplay.brand|capitalize}}
						</p>
						<p class="mb-1">
							{{translatedLabel.card_lastfour}}
							{{stancerForDisplay.last_four}}
						</p>
						<p class="mb-1">
							{{translatedLabel.card_expirationdate}}
							{{stancerForDisplay.expiration_date}}
						</p>
					</div>
				{% endif %}
				<div
					id="stancerPaymentInfo" class=" info-block-col col-xl-6">
					{# Put this in a proper table for better display #}
					<div class="row justify-content-between no-gutters">
            <p>
              <strong>{{translatedLabel.transaction_details}}</strong>
            </p>
					</div>
					<p class="mb-1">
						{{translatedLabel.amount_paid}}
            {{stancerForDisplay.total_amount}}
					</p>
          {% if stancerForDisplay.refunded_amount %}
						<p class="mb-1">
							{{translatedLabel.amount_refunded}} -{{stancerForDisplay.refunded_amount_formated}}
						</p>
						<p class="mb-1">
							{{translatedLabel.amount_remaining}}
							{{stancerForDisplay.refundable_amount_formated}}
						</p>
          {% elseif stancerForDisplay.status == 'canceled' %}
            <p class="mb-1">
              {{translatedLabel.payment_canceled}}
            </p>
          {% endif %}
          </div>
        </div>
      </div>
    </div>

  <div class="card-body">
    <div class="row mt-3">
    <div id="stancer_refund_form" class ="col-xxl-6 pr-4">
    {% if stancerForDisplay.refunded_amount != stancerForDisplay.raw_amount and stancerForDisplay.status != 'canceled' %}
    <div class ="card-body d-print-none">

      {{form_start(refundForm)}}
      <p class="mb-1">
        <strong>{{translatedLabel.refund_title}}</strong>
      </p>
      </br>
      {{ps.form_group_row(refundForm.refund_amount,{},{
        'label_on_top':true,
        'label': translatedLabel.amount,
        class:'mb-2',
      })}}
      {{ps.form_group_row(refundForm.change_invoice_status)}}
      {{form_row(refundForm.refund)}}
      {{form_rest(refundForm)}}
      {{form_end(refundForm)}}
      </div>
    {% endif %}
    </div>
  </div>
      <script>
        const refundForm = document.body.querySelector('#stancer_refund_form');
        const refundButton = refundForm.querySelector('#refund_stancer_payment_refund');
        const refundPriceInput = refundForm.querySelector('#refund_stancer_payment_refund_amount_amount');
        refundPriceInput.value = refundButton.getAttribute('data-refundable');
      </script>
    </div>
</div>
